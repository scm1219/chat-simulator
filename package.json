{
  "name": "chat-simulator",
  "version": "0.1.0",
  "description": "LLM 角色扮演聊天模拟器",
  "main": "out/main/index.mjs",
  "type": "module",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && npx electron-builder --win",
    "build:mac": "electron-vite build && npx electron-builder --mac",
    "build:linux": "electron-vite build && npx electron-builder --linux"
  },
  "build": {
    "appId": "com.chatsimulator.app",
    "productName": "Chat Simulator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.14.0",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "better-sqlite3": "^12.8.0",
    "electron": "^41.1.1",
    "electron-vite": "^5.0.0",
    "sass": "^1.99.0",
    "vite": "^8.0.3"
  }
}
